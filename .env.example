# ─────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your real credentials.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────

# Your Public.com API Secret Key.
# Auth flow: this secret is exchanged for a short-lived Bearer access token.
# Generate one at: https://public.com/settings/security/api
PUBLIC_SECRET_KEY=your_secret_key_here

# Set to "false" when you're ready to execute real trades.
# Defaults to "true" (dry-run / simulate only) if not set.
EMS_DRY_RUN=true

# ── Dashboard (dashboard.py) ──────────────────────────────────────────────────
# GitHub Personal Access Token for the local web dashboard.
# Create at: https://github.com/settings/tokens/new
# Required scopes: repo  (or at minimum: actions:read + actions:write)
GITHUB_PAT=ghp_your_token_here

# GitHub repo in owner/repo format.
GITHUB_REPO=Loudlarry/trade-manager
